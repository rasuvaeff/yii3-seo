{
    "name": "rasuvaeff/yii3-seo",
    "description": "Next.js-style typed SEO metadata for Yii3: title templates, OpenGraph, Twitter cards, hreflang, canonical URL, robots directives and JSON-LD",
    "license": "BSD-3-Clause",
    "type": "library",
    "keywords": [
        "seo",
        "meta",
        "metadata",
        "opengraph",
        "twitter-cards",
        "hreflang",
        "json-ld",
        "yii3"
    ],
    "authors": [
        {
            "name": "Victor Razuvaev",
            "email": "rasuvaeff@gmail.com"
        }
    ],
    "homepage": "https://github.com/rasuvaeff/yii3-seo",
    "support": {
        "issues": "https://github.com/rasuvaeff/yii3-seo/issues",
        "source": "https://github.com/rasuvaeff/yii3-seo"
    },
    "require": {
        "php": "^8.3",
        "ext-filter": "*",
        "yiisoft/html": "^3.13",
        "yiisoft/yii-view-renderer": "^7.4"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.51",
        "friendsofphp/php-cs-fixer": "^3.95",
        "httpsoft/http-message": "^1.1",
        "infection/infection": "^0.29",
        "maglnet/composer-require-checker": "^4.17",
        "phpunit/phpunit": "^11.5",
        "psalm/plugin-phpunit": "^0.19",
        "rector/rector": "^2.4",
        "vimeo/psalm": "^6.16"
    },
    "autoload": {
        "psr-4": {
            "Rasuvaeff\\Yii3Seo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rasuvaeff\\Yii3Seo\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true
        },
        "platform": {
            "php": "8.3.20"
        },
        "sort-packages": true
    },
    "extra": {
        "config-plugin": {
            "di": "di.php",
            "params": "params.php"
        },
        "config-plugin-options": {
            "source-directory": "config"
        }
    },
    "scripts": {
        "build": [
            "@composer validate --strict",
            "@composer normalize --dry-run",
            "@require-checker",
            "@cs",
            "@psalm",
            "@test"
        ],
        "cs": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.php",
        "cs:fix": "php-cs-fixer fix --diff --config=.php-cs-fixer.php",
        "mutation": "infection --threads=max",
        "psalm": "psalm --no-cache",
        "rector": "rector process --dry-run",
        "rector:fix": "rector process",
        "require-checker": "composer-require-checker check composer.json",
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text --coverage-clover=build/coverage.xml",
        "test:coverage:ci": "phpunit --coverage-clover=build/coverage.xml"
    }
}
